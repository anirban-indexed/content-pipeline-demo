{
  "client_name": "InspectMind AI",
  "domain": "inspectmind.ai",
  "cta_contact_url": "https://www.inspectmind.ai/get-started",
  "cta_pricing_url": "https://www.inspectmind.ai/pricing",
  "input_type": "content_plan",
  "react_spa": true,

  "_note_no_external_links": "Checker pages (/checkers/*) and compare pages (/compare/*) must contain ZERO external links. AEC standards bodies (nfpa.org, ashrae.org, aia.org, asce.org, aci-int.org, aisc.org) are the only permitted external links for non-checker/compare pages.",

